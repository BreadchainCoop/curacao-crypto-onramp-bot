# ─── Telegram ───────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ─── Sentoo (use sandbox values for MVP) ────────────────
# API secret — sent as the X-SENTOO-SECRET header on Sentoo API calls.
SENTOO_API_KEY=your_sentoo_api_key_here
SENTOO_MERCHANT_ID=your_sentoo_merchant_id_here
# Optional shared token appended to YOUR webhook URL (?token=…) as a basic auth
# layer. NOTE: Sentoo's webhook is a ping (transaction_id only); payment is
# confirmed by re-fetching status from the API — this is NOT a Sentoo HMAC.
SENTOO_WEBHOOK_SECRET=your_optional_webhook_url_token_here
# Sentoo API host — no trailing /v1 (the client appends /v1/payment/...).
# TODO(#6): confirm the exact sandbox host in the authenticated Sentoo docs.
SENTOO_BASE_URL=https://api.sentoo.io
# Browser redirect URL after payment (e.g. a deep link back to the bot).
SENTOO_RETURN_URL=https://t.me/your_bot

# ─── Privy ──────────────────────────────────────────────
PRIVY_APP_ID=your_privy_app_id_here
PRIVY_APP_SECRET=your_privy_app_secret_here

# ─── Synaps KYC ─────────────────────────────────────────
SYNAPS_API_KEY=your_synaps_api_key_here
SYNAPS_WEBHOOK_SECRET=your_synaps_webhook_secret_here

# ─── Blockchain / RPC ───────────────────────────────────
ALCHEMY_API_KEY=your_alchemy_api_key_here
RPC_URL=https://base-sepolia.g.alchemy.com/v2/your_alchemy_api_key_here

# ─── Smart contract ─────────────────────────────────────
ESCROW_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
ADMIN_WALLET_PRIVATE_KEY=your_admin_wallet_private_key_here_NEVER_COMMIT_THIS
# USDC token the escrow holds. Defaults to Circle's Base Sepolia USDC if unset.
USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e
# Basescan API key — used only for `hardhat verify` after deploy.
BASESCAN_API_KEY=your_basescan_api_key_here

# ─── Supabase ───────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ─── FX / pricing ───────────────────────────────────────
# XCG (Caribbean guilder) per 1 USDC. Sourced from the CBCS "Official Exchange
# Rates for Use by the Commercial Banks". The user buys USD (USDC), so the USD
# "Sell" rate applies: 1.82. Central parity is 1.79; NOT 1:1. See bot/lib/cbcsRates.js.
FX_PEG_RATE=1.82
# FX spread (margin baked into the rate), percent.
FX_SPREAD_PCT=1.5
# Platform fee switch — when true, captures a small fee into the exchange.
FX_FEE_ENABLED=true
# Platform fee, percent of order value (USDC notional).
FX_FEE_PCT=1.0
# Minimum fee in XCG, so tiny orders still cover fixed costs.
FX_FEE_FLAT_MIN_XCG=0.50

# ─── Orders ─────────────────────────────────────────────
# Minutes before an unpaid order is expired by the sweeper.
ORDER_TTL_MINUTES=30
# How often (ms) the expiry sweeper runs.
EXPIRY_SWEEP_MS=60000

# ─── Admin ──────────────────────────────────────────────
ADMIN_TELEGRAM_ID=your_telegram_user_id_here
